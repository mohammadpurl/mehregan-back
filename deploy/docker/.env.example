# Copy to Backend2/.env before: docker compose up -d
# ROTATE secrets (post-incident / prod): powershell -File .\scripts\generate_secrets.ps1
# Never commit real values. SECRET_KEY >= 32 chars required (fail-fast).

# Frontend build context (default: ../Frontend-Next3 → E:\ERP\Frontend-Next3\Dockerfile)
# Dev machine with extra /erp subfolder only: FRONTEND_CONTEXT=../Frontend-Next3/erp

# Optional: Docker Hub mirror when auth.docker.io returns 403
# PYTHON_IMAGE=docker.1ms.run/library/python:3.12-slim-bookworm
# NODE_IMAGE=docker.1ms.run/library/node:20-alpine
# POSTGRES_IMAGE=docker.1ms.run/library/postgres:16-alpine
# RABBITMQ_IMAGE=docker.1ms.run/library/rabbitmq:3.13-management-alpine

# --- Docker publish ports (direct access; does not use IIS 80/1396/1398) ---
# BACKEND_PUBLISH_PORT=8081
# FRONTEND_PUBLISH_PORT=8080

POSTGRES_USER=erp_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=task_management

# --- Backend auth ---
SECRET_KEY=CHANGE_ME_BACKEND_JWT_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Public URLs — split ports, no domain (replace SERVER_IP with your server IP) ---
ROOT_PATH=
API_PUBLIC_BASE_URL=http://SERVER_IP:8081
ALLOWED_ORIGINS=http://SERVER_IP:8080
NEXT_PUBLIC_API_URL=http://SERVER_IP:8081

# --- Frontend session (must differ from SECRET_KEY) ---
JWT_SERVER_SECRET=CHANGE_ME_FRONTEND_SESSION_SECRET

# --- Security ---
IP_WHITELIST_ENABLED=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
ENVIRONMENT=production
# API docs (/docs, /redoc, /openapi.json): off in production by default.
# Set ENABLE_API_DOCS=true only for trusted local/VPN debugging — never on the public internet.
# ENABLE_API_DOCS=false
# Create users with: python scripts/create_admin_user.py --username admin --password "..."

# --- OTP / SMS.ir ---
OTP_SECRET=CHANGE_ME
OTP_API_KEY=CHANGE_ME
OTP_TEMPLATE_ID=0
OTP_URL=https://api.sms.ir/v1/send/verify
OTP_STEP_SECONDS=120

# --- Optional ---
REDIS_ENABLED=false
# SENTRY_DSN=
