# Copy to Backend2/.env before: docker compose up -d
# Generate: [Convert]::ToBase64String((1..48 | ForEach-Object { Get-Random -Maximum 256 }))

# Frontend build context (default: ../Frontend-Next3 → E:\ERP\Frontend-Next3\Dockerfile)
# Dev machine with extra /erp subfolder only: FRONTEND_CONTEXT=../Frontend-Next3/erp

# Optional: Docker Hub mirror when auth.docker.io returns 403
# PYTHON_IMAGE=docker.1ms.run/library/python:3.12-slim-bookworm
# NODE_IMAGE=docker.1ms.run/library/node:20-alpine
# POSTGRES_IMAGE=docker.1ms.run/library/postgres:16-alpine
# RABBITMQ_IMAGE=docker.1ms.run/library/rabbitmq:3.13-management-alpine

POSTGRES_USER=erp_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=task_management

# --- Backend auth ---
SECRET_KEY=CHANGE_ME_BACKEND_JWT_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Public URLs (replace with your real domain) ---
ROOT_PATH=/backend
API_PUBLIC_BASE_URL=https://erp.example.com/backend
ALLOWED_ORIGINS=https://erp.example.com
NEXT_PUBLIC_API_URL=https://erp.example.com/backend

# --- Frontend session (must differ from SECRET_KEY) ---
JWT_SERVER_SECRET=CHANGE_ME_FRONTEND_SESSION_SECRET

# --- Security ---
IP_WHITELIST_ENABLED=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
ENVIRONMENT=production

# --- OTP / SMS.ir ---
OTP_SECRET=CHANGE_ME
OTP_API_KEY=CHANGE_ME
OTP_TEMPLATE_ID=0
OTP_URL=https://api.sms.ir/v1/send/verify
OTP_STEP_SECONDS=120

# --- Optional ---
REDIS_ENABLED=false
# SENTRY_DSN=
