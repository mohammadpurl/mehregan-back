# Copy secrets into Backend2/.env (never commit .env)
# Generate: [Convert]::ToBase64String((1..48 | ForEach-Object { Get-Random -Maximum 256 }))

# --- Mirror (when Docker Hub 403) ---
# PYTHON_IMAGE=docker.1ms.run/library/python:3.12-slim-bookworm
# NODE_IMAGE=docker.1ms.run/library/node:20-alpine
# POSTGRES_IMAGE=docker.1ms.run/library/postgres:16-alpine
# RABBITMQ_IMAGE=docker.1ms.run/library/rabbitmq:3.13-alpine
# CADDY_IMAGE=docker.1ms.run/library/caddy:2.8-alpine

# --- Frontend path on server (no /erp) ---
FRONTEND_CONTEXT=../../../../Frontend-Next3
FRONTEND_DOCKERFILE=../Backend2/deploy/docker/secure/Dockerfile.frontend

# --- Database ---
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=task_management

# --- RabbitMQ ---
RABBITMQ_USER=erp_mq
RABBITMQ_PASSWORD=CHANGE_ME_STRONG_MQ_PASSWORD

# --- Backend JWT ---
SECRET_KEY=CHANGE_ME_BACKEND_JWT_SECRET_64CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Frontend session (MUST differ from SECRET_KEY) ---
JWT_SERVER_SECRET=CHANGE_ME_FRONTEND_SESSION_SECRET_64CHARS

# --- Public URLs (path-based via Caddy on :80) ---
# Replace SERVER_IP with your public or LAN IP
ROOT_PATH=
API_PUBLIC_BASE_URL=http://SERVER_IP/backend
ALLOWED_ORIGINS=http://SERVER_IP
NEXT_PUBLIC_API_URL=http://SERVER_IP/backend

# --- Security ---
IP_WHITELIST_ENABLED=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=30
ENVIRONMENT=production

# --- OTP (optional) ---
OTP_SECRET=CHANGE_ME
OTP_API_KEY=CHANGE_ME
OTP_TEMPLATE_ID=0
OTP_URL=https://api.sms.ir/v1/send/verify
OTP_STEP_SECONDS=120
