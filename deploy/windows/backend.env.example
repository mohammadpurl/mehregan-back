# Mehreagan ERP — Backend production (.env)
# Copy to: C:\apps\mehreagan\Backend2\.env
# ROTATE all secrets after incident / for prod:
#   powershell -File .\scripts\generate_secrets.ps1
# SECRET_KEY must be >= 32 characters (app refuses insecure defaults).

# --- Database (choose ONE approach) ---
DATABASE_URL=postgresql+psycopg://erp_user:CHANGE_ME@127.0.0.1:5432/task_management
# POSTGRES_USER=erp_user
# POSTGRES_PASSWORD=CHANGE_ME
# POSTGRES_SERVER=127.0.0.1
# POSTGRES_PORT=5432
# POSTGRES_DB=task_management

# --- Auth / JWT (backend) ---
SECRET_KEY=CHANGE_ME_USE_openssl_or_PowerShell_random_64_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Public URLs (replace erp.example.com) ---
ROOT_PATH=/backend
API_PUBLIC_BASE_URL=https://erp.example.com/backend
ALLOWED_ORIGINS=https://erp.example.com

# --- Security ---
# For public ERP: must be false (otherwise browser users get 403)
IP_WHITELIST_ENABLED=false
# ALLOWED_IPS=127.0.0.1,10.0.0.0/8

RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
# ENABLE_API_DOCS=false  # default off when ENVIRONMENT=production
# Create admin: python scripts/create_admin_user.py --username admin --password "..."

# Optional field-level encryption (if used)
# ENCRYPTION_KEY=

# --- Storage ---
UPLOAD_DIR=C:\apps\mehreagan\Backend2\data\uploads

# --- OTP / SMS.ir ---
OTP_SECRET=CHANGE_ME
OTP_STEP_SECONDS=120
OTP_DRIFT_WINDOWS=1
OTP_URL=https://api.sms.ir/v1/send/verify
OTP_API_KEY=CHANGE_ME
OTP_TEMPLATE_ID=0

# --- Redis (optional) ---
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379/0

# --- Logging / monitoring ---
ENVIRONMENT=production
LOG_LEVEL=INFO
LOG_FORMAT=plain
# SENTRY_DSN=
# SENTRY_ENV=production

# --- AI features (optional — omit if unused) ---
# OPENAI_API_KEY=
# OLLAMA_MODEL=
