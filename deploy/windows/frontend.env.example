# Mehreagan ERP — Frontend production
# Copy to: C:\apps\mehreagan\Frontend-Next3\erp\.env.production
# Or rename to .env.local on the server before `npm run build`

# Session cookie signing (must differ from backend SECRET_KEY)
JWT_SERVER_SECRET=CHANGE_ME_DIFFERENT_FROM_BACKEND_SECRET

# Browser calls public HTTPS URL (via IIS)
NEXT_PUBLIC_API_URL=https://erp.example.com/backend

# Next.js server-side calls local API (never exposed to internet)
API_URL=http://127.0.0.1:8000/backend
