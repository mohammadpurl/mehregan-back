<?xml version="1.0" encoding="UTF-8"?>
<!--
  Mehreagan ERP — IIS reverse proxy (Windows Server)

  Setup:
  1. Install IIS + URL Rewrite + Application Request Routing (ARR)
  2. IIS Manager → Server → ARR → Server Proxy Settings → Enable proxy
  3. Create site bound to https://YOUR_DOMAIN (e.g. erp.example.com)
  4. Set site physical path to this folder (only web.config is required here)
  5. Ensure backend (127.0.0.1:8000) and frontend (127.0.0.1:3000) Windows services are running

  Replace YOUR_DOMAIN in comments/docs; no domain string is hardcoded in rewrite rules.
-->
<configuration>
  <system.webServer>
    <security>
      <requestFiltering>
        <!-- 35 MB — matches Next.js serverActions bodySizeLimit -->
        <requestLimits maxAllowedContentLength="36700160" />
      </requestFiltering>
    </security>

    <httpProtocol>
      <customHeaders>
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>

    <rewrite>
      <rules>
        <!-- Force HTTPS (when SSL termination is on this site) -->
        <rule name="HTTP to HTTPS" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="off" ignoreCase="true" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
        </rule>

        <!-- Block Swagger / OpenAPI in production -->
        <rule name="Block API Docs" stopProcessing="true">
          <match url="^backend/(docs|redoc|openapi\.json)(/.*)?$" ignoreCase="true" />
          <action type="CustomResponse" statusCode="404" statusReason="Not Found" statusDescription="Not Found" />
        </rule>

        <!-- WebSocket notifications — backend /ws -->
        <rule name="WebSocket Proxy" stopProcessing="true">
          <match url="^ws(.*)$" ignoreCase="true" />
          <action type="Rewrite" url="http://127.0.0.1:8000/ws{R:1}" />
        </rule>

        <!-- Static uploads served by FastAPI mount (optional direct proxy) -->
        <rule name="Uploads Proxy" stopProcessing="true">
          <match url="^uploads/(.*)$" ignoreCase="true" />
          <action type="Rewrite" url="http://127.0.0.1:8000/uploads/{R:1}" />
        </rule>

        <!-- Backend API: /backend/auth → http://127.0.0.1:8000/auth -->
        <rule name="Backend API Proxy" stopProcessing="true">
          <match url="^backend/(.*)$" ignoreCase="true" />
          <action type="Rewrite" url="http://127.0.0.1:8000/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
            <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
          </serverVariables>
        </rule>

        <!-- Next.js frontend — all other paths -->
        <rule name="Frontend Proxy" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="http://127.0.0.1:3000/{R:1}" />
        </rule>
      </rules>
    </rewrite>

    <webSocket enabled="true" />
  </system.webServer>
</configuration>
